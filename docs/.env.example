# =============================================================================
# Good4NCU Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Required variables MUST be set before running the application.

# -----------------------------------------------------------------------------
# LLM Configuration (Required: at least one must be set)
# -----------------------------------------------------------------------------

# Google Gemini API Key (required unless using minimax-only mode with separate embeddings)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MiniMax API Key (only required if LLM_PROVIDER=minimax)
# MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax API Base URL (optional, defaults to https://api.minimax.chat)
# MINIMAX_API_BASE_URL=https://api.minimax.chat

# LLM Provider to use: "gemini" (default) or "minimax"
# When using minimax, GEMINI_API_KEY is still required for embeddings
# LLM_PROVIDER=gemini

# Embedding vector dimensions (default: 768)
# VECTOR_DIM=768

# -----------------------------------------------------------------------------
# Authentication (Required)
# -----------------------------------------------------------------------------

# JWT secret for token signing - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_characters_long_here

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/good4ncu

# -----------------------------------------------------------------------------
# CORS Configuration (Optional)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins
# Use "*" to allow all origins (not recommended for production)
# Use "http://localhost:3000" for local development
# CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# -----------------------------------------------------------------------------
# Content Moderation (Optional)
# -----------------------------------------------------------------------------

# Comma-separated list of blocked keywords for content moderation
# BLOCKED_KEYWORDS=毒品,武器

# -----------------------------------------------------------------------------
# Alibaba Cloud OSS (Optional - for file uploads)
# -----------------------------------------------------------------------------

# OSS endpoint (defaults to Beijing region)
# OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

# OSS bucket name (defaults to "good4ncu")
# OSS_BUCKET=good4ncu

# RAM Role ARN for STS authentication (optional)
# OSS_ROLE_ARN=acs:ram::123456:role/YourRole

# Access Key credentials (optional - omit if using STS role)
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret

# -----------------------------------------------------------------------------
# Rate Limiting (Optional — defaults to local moka cache, single-node)
# Enable Redis for multi-node horizontal scaling (requires --features redis build)
# -----------------------------------------------------------------------------

# Redis URL for distributed rate limiter (optional — omit for single-node)
# When set, the app uses Redis sorted-set sliding window instead of local moka cache.
# REDIS_URL=redis://localhost:6379

# Maximum requests per IP per window (default: 100)
# RATE_LIMIT_MAX_REQUESTS=100

# Rate limit window in seconds (default: 60)
# RATE_LIMIT_WINDOW_SECS=60
